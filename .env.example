# =============================================================================
# MapinData SDK — Ortam Değişkenleri Şablonu
# =============================================================================
# BU DOSYAYI KOPYALA: cp .env.example .env
# .env dosyası .gitignore içinde yer alır — asla commit edilmez.
# Üretim ortamında bu değerler sistem ortam değişkeni olarak set edilir.
# =============================================================================

# --- AWS / S3 ----------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=eu-central-1

MAPIN_S3_BUCKET=mapindata-prod
MAPIN_S3_RAW_PREFIX=raw/
MAPIN_S3_PROCESSED_PREFIX=processed/

# --- PostgreSQL / Veritabanı -------------------------------------------------
MAPIN_DB_HOST=localhost
MAPIN_DB_PORT=5432
MAPIN_DB_NAME=mapindata
MAPIN_DB_USER=mapindata_user
MAPIN_DB_PASSWORD=your-db-password
MAPIN_DB_POOL_SIZE=5
MAPIN_DB_MAX_OVERFLOW=10

# --- Spark -------------------------------------------------------------------
# Boş bırakılırsa SparkManager sistemi otomatik olarak profilar (RAM/Core).
SPARK_DRIVER_MEMORY=
SPARK_EXECUTOR_MEMORY=
SPARK_EXECUTOR_CORES=

# --- Kazıma / Scraping -------------------------------------------------------
MAPIN_SCRAPER_EC2_URL=http://your-ec2-instance:8080
MAPIN_SCRAPER_API_KEY=your-scraper-api-key

APIFY_API_TOKEN=your-apify-token
ROCKET_API_KEY=your-rocket-api-key
MAPIN_LIVE_TRACKER_TOKEN=your-live-tracker-token

# --- NLP / Google Reviews ----------------------------------------------------
# transformers modelinin yerel cache dizini
HF_HOME=/tmp/huggingface_cache
MAPIN_SENTIMENT_MODEL=savasy/bert-base-turkish-sentiment-cased

# --- Genel -------------------------------------------------------------------
MAPIN_ENV=development   # development | staging | production
MAPIN_LOG_LEVEL=INFO
